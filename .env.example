# ============================================================
#  Zammad - Environment Variables
#  Salin file ini: cp .env.example .env
#  Lalu sesuaikan nilainya sebelum menjalankan docker compose
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=zammad
POSTGRES_PASSWORD=ZammadPassw0rd!   # GANTI dengan password yang kuat
POSTGRES_HOST=zammad-postgresql
POSTGRES_PORT=5432

# --- Zammad App ---
POSTGRESQL_USER=zammad
POSTGRESQL_PASS=ZammadPassw0rd!     # Harus sama dengan POSTGRES_PASSWORD
POSTGRESQL_HOST=zammad-postgresql
POSTGRESQL_PORT=5432
POSTGRESQL_DB=zammad_production
POSTGRESQL_OPTIONS=

# --- Elasticsearch ---
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_HOST=zammad-elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEMA=http
ELASTICSEARCH_NAMESPACE=zammad
ELASTICSEARCH_REINDEX=true

# --- Memcached ---
MEMCACHE_SERVERS=zammad-memcached:11211

# --- Redis ---
REDIS_URL=redis://zammad-redis:6379

# --- Rails ---
RAILS_ENV=production
RAILS_LOG_STDOUT=true
RAILS_TRUSTED_PROXIES=127.0.0.1,::1

# --- Zammad Application URL ---
# Ganti dengan domain/IP server Anda jika deploy ke server
# Contoh: http://zammad.contoh.com atau http://192.168.1.100:8080
ZAMMAD_FQDN=localhost

# --- Backup (opsional) ---
# BACKUP_TIME=03:00
# HOLD_DAYS=10
